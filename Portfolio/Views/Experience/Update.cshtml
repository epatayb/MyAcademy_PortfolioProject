@model Experience

@{
    Layout = "~/Views/Admin/Layout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">İş Deneyimini Güncelle</h2>

        <p class="admin-page-description">
            Seçilen deneyim kaydının bilgilerini düzenleyebilirsiniz.
        </p>
    </div>

    <a asp-controller="Experience"
       asp-action="Index"
       class="btn btn-outline-secondary">
        <span class="material-symbols-outlined align-middle me-1"
              style="font-size: 19px;">
            arrow_back
        </span>
        Listeye Dön
    </a>
</div>

<div class="admin-form-card shadow-sm">

    <form asp-controller="Experience"
          asp-action="Update"
          method="post">

        <input asp-for="Id" type="hidden" />

        <div class="admin-form-body">
            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="Title" class="admin-form-label">
                        Pozisyon
                    </label>

                    <input asp-for="Title"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="Title"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Company" class="admin-form-label">
                        Şirket
                    </label>

                    <input asp-for="Company"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="Company"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StartYear" class="admin-form-label">
                        Başlangıç Tarihi
                    </label>

                    <input asp-for="StartYear"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="StartYear"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-md-6">
                    <label asp-for="EndYear" class="admin-form-label">
                        Bitiş Tarihi
                    </label>

                    <input asp-for="EndYear"
                           id="endYear"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="EndYear"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-12">
                    <div class="admin-option-box">
                        <div class="form-check form-switch">
                            <input asp-for="IsCurrent"
                                   id="experienceCurrent"
                                   class="form-check-input"
                                   type="checkbox" />

                            <label asp-for="IsCurrent"
                                   class="form-check-label fw-semibold">
                                Bu pozisyonda hâlâ çalışıyorum
                            </label>
                        </div>

                        <p class="admin-option-description">
                            Seçildiğinde bitiş tarihi temizlenir.
                        </p>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="admin-form-label">
                        Görev ve Sorumluluklar
                    </label>

                    <textarea asp-for="Description"
                              maxlength="1000"
                              class="form-control admin-form-control"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger small">
                    </span>
                </div>
            </div>
        </div>

        <div class="admin-form-footer">
            <button type="submit" class="btn btn-primary">
                <span class="material-symbols-outlined align-middle me-1"
                      style="font-size: 19px;">
                    check
                </span>
                Değişiklikleri Kaydet
            </button>                       
        </div>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const currentCheckbox =
            document.getElementById("experienceCurrent");

        const endYear =
            document.getElementById("endYear");

        function updateEndYear() {
            endYear.disabled = currentCheckbox.checked;

            if (currentCheckbox.checked) {
                endYear.value = "";
            }
        }

        currentCheckbox.addEventListener(
            "change",
            updateEndYear
        );

        updateEndYear();
    });
</script>