@model TechStackEditViewModel

@{
    Layout = "~/Views/Admin/Layout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">
            Teknolojiyi Güncelle
        </h2>

        <p class="admin-page-description">
            Seçilen teknolojinin görünen adını değiştirebilirsiniz.
        </p>
    </div>

    <a asp-controller="TechStack"
       asp-action="Index"
       class="btn btn-outline-secondary">

        <span class="material-symbols-outlined align-middle me-1"
              style="font-size: 18px;">
            arrow_back
        </span>

        Listeye Dön
    </a>
</div>

<div class="admin-form-card shadow-sm">

    <form asp-controller="TechStack"
          asp-action="Update"
          method="post">

        <input asp-for="Id" type="hidden" />

        <div class="admin-form-body">
            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger mb-4">
            </div>

            <div class="row g-4">
                <div class="col-lg-12">
                    <label asp-for="Name"
                           class="admin-form-label">
                        Teknoloji Adı
                    </label>

                    <input asp-for="Name"
                           class="form-control admin-form-control"
                           placeholder="Örneğin: Entity Framework Core"
                           autocomplete="off" />

                    <div class="admin-form-help">
                        Bu değişiklik teknolojinin bağlı olduğu tüm projelerde
                        geçerli olacaktır.
                    </div>

                    <span asp-validation-for="Name"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-12">
                    <div class="admin-info-box">
                        <span class="material-symbols-outlined">
                            sync
                        </span>

                        <div>
                            <div class="fw-semibold">
                                Bağlı projeler korunur
                            </div>

                            <div class="small mt-1">
                                Teknolojinin adını güncellemek mevcut proje
                                bağlantılarını veya sıralamalarını değiştirmez.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-form-footer">
            <button type="submit"
                    class="btn btn-primary">

                <span class="material-symbols-outlined align-middle me-1"
                      style="font-size: 18px;">
                    check
                </span>

                Değişiklikleri Kaydet
            </button>
        </div>
    </form>
</div>