@model List<TechStack>

@{
    Layout = "~/Views/Admin/Layout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">
            Teknolojiler
        </h2>

        <p class="admin-page-description">
            Projelerinizde kullandığınız teknolojileri buradan yönetebilirsiniz.
        </p>
    </div>

    <a asp-controller="TechStack"
       asp-action="Create"
       class="btn btn-primary">

        <span class="material-symbols-outlined align-middle me-1"
              style="font-size: 19px;">
            add
        </span>

        Yeni Teknoloji Ekle
    </a>
</div>

<div class="admin-table-card shadow-sm">
    @if (Model.Any())
    {
        <div class="admin-table-scroll">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Teknoloji</th>
                        <th>Kullanıldığı Proje Sayısı</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var techStack in Model)
                    {
                        var projectCount = techStack.ProjectTechStacks?
                        .Select(x => x.ProjectId)
                        .Distinct()
                        .Count() ?? 0;

                        <tr>
                            <td>
                                <div class="admin-item-with-icon">
                                    <div class="admin-item-icon">
                                        <span class="material-symbols-outlined">
                                            terminal
                                        </span>
                                    </div>

                                    <div>
                                        <div class="admin-item-title">
                                            @techStack.Name
                                        </div>

                                        <div class="admin-item-subtitle">
                                            Teknoloji #@techStack.Id
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="admin-count-badge">
                                    @projectCount
                                </span>
                            </td>

                            <td>
                                <div class="admin-actions justify-content-end">
                                    <a asp-controller="TechStack"
                                       asp-action="Update"
                                       asp-route-id="@techStack.Id"
                                       class="btn btn-sm btn-outline-primary">

                                        <span class="material-symbols-outlined align-middle"
                                              style="font-size: 17px;">
                                            edit
                                        </span>

                                        Güncelle
                                    </a>

                                    <form asp-controller="TechStack"
                                          asp-action="Delete"
                                          method="post"
                                          class="m-0">

                                        <input type="hidden"
                                               name="id"
                                               value="@techStack.Id" />

                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="confirmTechDelete(this)">

                                            <span class="material-symbols-outlined align-middle"
                                                  style="font-size: 17px;">
                                                delete
                                            </span>

                                            Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="admin-empty">
            <div class="admin-empty-icon">
                <span class="material-symbols-outlined">
                    terminal
                </span>
            </div>

            <h5>Henüz teknoloji eklenmedi</h5>

            <p class="text-muted mb-4">
                Projelerinizde kullandığınız teknolojileri ekleyebilirsiniz.
            </p>

            <a asp-controller="TechStack"
               asp-action="Create"
               class="btn btn-primary">

                <span class="material-symbols-outlined align-middle me-1"
                      style="font-size: 19px;">
                    add
                </span>

                Yeni Teknoloji Ekle
            </a>
        </div>
    }
</div>

<script>
    function confirmTechDelete(button) {
        const form = button.closest("form");

        Swal.fire({
            title: "Teknoloji kaldırılsın mı?",
            text: "Bu teknoloji projelerde artık gösterilmeyecektir.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc3545",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Evet, kaldır",
            cancelButtonText: "İptal"
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    }
</script>