@model List<Project>
@{
    Layout = "~/Views/Admin/Layout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Projelerim</h2>

        <p class="admin-page-description">
            Portfolyo sayfanızda gösterilen projeleri ve teknolojilerini yönetin.
        </p>
    </div>

    <a asp-controller="Project"
       asp-action="Create"
       class="btn btn-primary">
        <span class="material-symbols-outlined align-middle me-1"
              style="font-size: 19px;">
            add
        </span>

        Yeni Proje Ekle
    </a>
</div>

<div class="admin-table-card shadow-sm">
    <div class="admin-table-scroll">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Proje</th>
                    <th>Açıklama</th>
                    <th>Teknolojiler</th>
                    <th>Github</th>
                    <th>Gösterim Sırası</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var project in Model)
                {
                    <tr>

                        <td>
                            <div class="admin-item-with-icon">
                                <img src="/images/@project.ImageUrl"
                                     alt="@project.Name"
                                     class="admin-project-image" />

                                <div class="admin-item-title">
                                    @project.Name
                                </div>

                            </div>
                        </td>

                        <td>
                            <div class="admin-item-description">
                                @project.Description
                            </div>
                        </td>

                        <td>
                            @if (project.ProjectTechStacks?.Any() == true)
                            {
                                <div class="admin-badge-list">
                                    @foreach (var relation in project.ProjectTechStacks
                                                                .OrderBy(x => x.SortOrder))
                                    {
                                        <span class="admin-tech-badge">
                                            @relation.TechStack.Name
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">Teknoloji Eklenmedi</span>
                            }
                        </td>

                        <td>
                            @if (!string.IsNullOrWhiteSpace(project.GithubUrl))
                            {
                                <a href="@project.GithubUrl"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="btn btn-sm btn-outline-dark">

                                    <span class="material-symbols-outlined align-middle"
                                          style="font-size: 17px;">
                                        open_in_new
                                    </span>

                                    GitHub
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">Link yok</span>
                            }
                        </td>

                        <td>
                            <span class="admin-order-badge">
                                @project.DisplayOrder
                            </span>
                        </td>

                        <td>
                            <div class="admin-actions">

                                <a asp-controller="ProjectTechStacks"
                                   asp-action="Add"
                                   asp-route-projectId="@project.Id"
                                   class="btn btn-sm btn-outline-success">
                                    <span class="material-symbols-outlined align-middle"
                                          style="font-size: 17px;">
                                        terminal
                                    </span>
                                    TeknoloJiler
                                </a>

                                <a asp-controller="Project"
                                   asp-action="Update"
                                   asp-route-id="@project.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <span class="material-symbols-outlined align-middle"
                                          style="font-size: 17px;">
                                        edit
                                    </span>
                                    Güncelle
                                </a>

                                <form asp-controller="Project"
                                      asp-action="Delete"
                                      method="post"
                                      class="mb-0">

                                    <input type="hidden"
                                           name="id"
                                           value="@project.Id" />

                                    <button type="button"
                                            onclick="confirmDelete(this)"
                                            class="btn btn-sm btn-outline-danger">
                                        <span class="material-symbols-outlined align-middle"
                                              style="font-size: 17px;">
                                            delete
                                        </span>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>


<script>
    function confirmDelete(button) {
        const form = button.closest("form");

        Swal.fire({
      title: "Silmek istediğinize emin misiniz?",
      text: "Bu işlemi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Evet, Sil!",
      cancelButtonText : "İptal"
    }).then((result) => {
      if (result.isConfirmed)
        {
            form.submit();
        }
    });

    }
</script>