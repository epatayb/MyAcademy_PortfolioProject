@model List<Project>
@{
    ViewData["Title"] = "Projelerim";
    Layout = "~/Views/Admin/Layout.cshtml";
}

<table class="table table-hover table-bordered">
    <tr>
        <th>Görsel</th>
        <th>Proje Adı</th>
        <th>Proje Açıklaması</th>
        <th>Teknoloiler</th>
        <th>Github Linki</th>
        <th>Gösterim Sırası</th>
        <th>İşlemler</th>
    </tr>

    @foreach (var project in Model)
    {
        <tr>
            <td>
                <img src="/images/@project.ImageUrl" alt="@project.Name" style="width: 50px; height: 50px;" />
            </td>
            <td>@project.Name</td>
            <td>@project.Description</td>
            <td>
                @if (project.ProjectTechStacks.Any())
                {
                    <div class="d-flex flex-wrap" style="gap: 6px;">
                        @foreach (var relation in project.ProjectTechStacks
                                        .OrderBy(x => x.SortOrder))
                        {
                            <span class="tech-badge">
                                @relation.TechStack.Name
                            </span>
                        }
                    </div>
                }
                else
                {
                    <span class="text-muted">Teknoloji Eklenmedi</span>
                }
            </td>
            <td><a href="@project.GithubUrl" target="_blank" class="btn btn-sm btn-outline-dark align-items-center">Github Url</a></td>
            <td class="px-4 py-3">
                <span class="inline-flex items-center justify-center min-w-8 h-8 rounded-full bg-primary/10 text-primary font-semibold">
                    @project.DisplayOrder
                </span>
            </td>
            <td>
                <div class="d-flex align-items-center gap-2 flex-wrap">

                    <a asp-controller="ProjectTechStacks"
                       asp-action="Add"
                       asp-route-projectId="@project.Id"
                       class="btn btn-sm btn-outline-success">
                        TeknoloJiler
                    </a>

                    <a href="@Url.Action("Update", "Project", new { id = project.Id })"
                       class="btn btn-sm btn-outline-primary">
                        Güncelle
                    </a>

                    <button type="button"
                            onclick="confirmDelete(@project.Id)"
                            class="btn btn-sm btn-outline-danger">
                        Sil
                    </button>
                </div>
            </td>
        </tr>
    }

</table>

<a href="@Url.Action("Create", "Project")" class="btn btn-outline-dark">Yeni Proje Ekle</a>


<script>
    function confirmDelete(id) {

        Swal.fire({
      title: "Silmek istediğinize emin misiniz?",
      text: "Bu işlemi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Evet, Sil!",
      cancelButtonText : "İptal"
    }).then((result) => {
      if (result.isConfirmed)
        {
            window.location.href = '/Project/Delete/' + id;
        }
    });

    }
</script>