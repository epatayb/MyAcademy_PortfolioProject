@model Project
@{
    ViewData["Title"] = "Projeyi Güncelle";
    Layout = "~/Views/Admin/Layout.cshtml";
}

<form method="post">
    <input type="hidden" asp-for="Id" />

    <label>Proje Adı</label>
    <input type="text" asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
    <br />

    <label>Görsel Url</label>
    <input type="text" asp-for="ImageUrl" class="form-control" />
    <span asp-validation-for="ImageUrl" class="text-danger"></span>
    <br />

    <label>Proje Açıklaması</label>
    <textarea type="text" asp-for="Description" class="form-control rows="3"> </textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
    <br />

    <label>Github URL</label>
    <input type="url" asp-for="GithubUrl" class="form-control" />
    <span asp-validation-for="GithubUrl" class="text-danger"></span>
    <br />

    <button type="submit" class="btn btn-outline-dark">Güncelle</button>
</form>
