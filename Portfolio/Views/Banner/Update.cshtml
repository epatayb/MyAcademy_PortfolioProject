@model Banner

@{
    Layout = "~/Views/Admin/Layout.cshtml";
}

<style>
    .banner-edit-card {
        overflow: hidden;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
    }

    .banner-edit-preview {
        position: relative;
        height: 280px;
        overflow: hidden;
        background: #0f172a;
    }

        .banner-edit-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .65;
        }

    .banner-edit-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        padding: 25px;
        color: #fff;
        background: linear-gradient( to top, rgba(15, 23, 42, .95), transparent );
    }

    .banner-edit-body {
        padding: 26px;
    }

    .banner-edit-footer {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 18px 26px;
        background: #f8fafc;
        border-top: 1px solid #e2e8f0;
    }

    .banner-form-label {
        margin-bottom: 7px;
        color: #334155;
        font-size: 14px;
        font-weight: 600;
    }

    .banner-form-control {
        min-height: 45px;
        border-color: #cbd5e1;
        border-radius: 9px;
    }

    textarea.banner-form-control {
        min-height: 150px;
        resize: vertical;
    }
</style>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="mb-1 fw-bold">Bannerı Güncelle</h2>

        <p class="text-muted mb-0">
            Ana sayfada gösterilen banner içeriğini düzenleyin.
        </p>
    </div>

    <a asp-controller="Banner"
       asp-action="Index"
       class="btn btn-outline-secondary">
        <span class="material-symbols-outlined align-middle me-1"
              style="font-size: 19px;">
            arrow_back
        </span>
        Listeye Dön
    </a>
</div>

<div class="banner-edit-card shadow-sm">
    <div class="banner-edit-preview">
        <img src="/images/@Model.ImageUrl"
             alt="@Model.Title"
             id="bannerPreviewImage" />
    </div>

    <form asp-controller="Banner"
          asp-action="Update"
          method="post">

        <input asp-for="Id" type="hidden" />

        <div class="banner-edit-body">
            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="row g-4">
                <div class="col-12">
                    <label asp-for="Title"
                           class="banner-form-label">
                        Başlık
                    </label>

                    <input asp-for="Title"
                           class="form-control banner-form-control" />

                    <span asp-validation-for="Title"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-12">
                    <label asp-for="ImageUrl"
                           class="banner-form-label">
                        Görsel Dosya Adı
                    </label>

                    <input asp-for="ImageUrl"
                           id="imageUrlInput"
                           class="form-control banner-form-control" />

                    <div class="form-text">
                        Görselin wwwroot/images klasöründe bulunması gerekir.
                    </div>

                    <span asp-validation-for="ImageUrl"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-12">
                    <label asp-for="Description"
                           class="banner-form-label">
                        Açıklama
                    </label>

                    <textarea asp-for="Description"
                              maxlength="1000"
                              class="form-control banner-form-control"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger small">
                    </span>
                </div>
            </div>
        </div>

        <div class="banner-edit-footer">
            <button type="submit"
                    class="btn btn-primary">
                <span class="material-symbols-outlined align-middle me-1"
                      style="font-size: 19px;">
                    check
                </span>
                Değişiklikleri Kaydet
            </button>
        </div>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const imageInput =
            document.getElementById("imageUrlInput");

        const previewImage =
            document.getElementById("bannerPreviewImage");

        imageInput.addEventListener("input", function () {
            const imageName = imageInput.value.trim();

            if (imageName) {
                previewImage.src = "/images/" + imageName;
            }
        });
    });
</script>