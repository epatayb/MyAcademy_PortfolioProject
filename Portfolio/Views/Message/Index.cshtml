@model List<UserMessage>

@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Views/Admin/Layout.cshtml";

    var unreadCount = Model.Count(x => !x.IsRead);
    var readCount = Model.Count(x => x.IsRead);
}


<div class="mb-4">
    <h2 class="mb-1 fw-bold">Gelen Mesajlar</h2>

    <p class="text-muted mb-0">
        İletişim formundan gönderilen mesajları buradan yönetebilirsiniz.
    </p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="message-stat-card">
            <div>
                <div class="message-stat-title">Toplam Mesaj</div>
                <div class="message-stat-value">@Model.Count</div>
            </div>
            <div class="stat-icon-wrapper stat-icon-total">
                <span class="material-symbols-outlined">
                    inbox
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="message-stat-card">
            <div>
                <div class="message-stat-title">Yeni Mesaj</div>
                <div class="message-stat-value text-primary">@unreadCount</div>
            </div>
            <div class="stat-icon-wrapper stat-icon-unread">
                <span class="material-symbols-outlined">
                    mark_email_unread
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="message-stat-card">
            <div>
                <div class="message-stat-title">Okunan Mesaj</div>
                <div class="message-stat-value text-success">@readCount</div>
            </div>
            <div class="stat-icon-wrapper stat-icon-read">
                <span class="material-symbols-outlined">
                    mark_email_read
                </span>
            </div>
        </div>
    </div>
</div>

<div class="message-list-card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover message-table">
                <thead>
                    <tr>
                        <th>Gönderen</th>
                        <th>Mesaj</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var message in Model)
                    {
                        var summary = message.MessageBody.Length > 90
                        ? message.MessageBody[..90] + "..."
                        : message.MessageBody;

                        var firstLetter = string.IsNullOrWhiteSpace(message.Name)
                        ? "?"
                        : message.Name[..1].ToUpper();

                        <tr class="@(!message.IsRead ? "unread-message-row" : "")">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="sender-avatar">
                                        @firstLetter
                                    </span>

                                    <div>
                                        <div class="sender-name">
                                            @message.Name
                                        </div>

                                        <a href="mailto:@message.Email"
                                           class="sender-email">
                                            @message.Email
                                        </a>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="message-summary">
                                    @summary
                                </div>
                            </td>

                            <td>
                                <div class="message-date">
                                    <div>
                                        @message.CreatedDate.ToString("dd.MM.yyyy")
                                    </div>

                                    <div>
                                        @message.CreatedDate.ToString("HH:mm")
                                    </div>
                                </div>
                            </td>

                            <td>
                                @if (message.IsRead)
                                {
                                    <span class="message-status message-status-read">
                                        Okundu
                                    </span>
                                }
                                else
                                {
                                    <span class="message-status message-status-new">
                                        Yeni
                                    </span>
                                }
                            </td>

                            <td>
                                <div class="message-actions justify-content-end">
                                    <a asp-controller="Message"
                                       asp-action="Detail"
                                       asp-route-id="@message.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <span class="material-symbols-outlined align-middle me-1"
                                              style="font-size: 17px;">
                                            visibility
                                        </span>
                                        Görüntüle
                                    </a>

                                    @if (message.IsRead)
                                    {
                                        <form asp-controller="Message"
                                              asp-action="MarkAsUnread"
                                              method="post"
                                              class="m-0">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@message.Id" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-secondary">
                                                <span class="material-symbols-outlined align-middle me-1" style="font-size: 17px;">
                                                    mark_email_unread
                                                </span>
                                                Okunmadı Yap
                                            </button>
                                        </form>
                                    }

                                    <form asp-controller="Message"
                                          asp-action="Delete"
                                          method="post"
                                          class="m-0 delete-message-form">

                                        <input type="hidden"
                                               name="id"
                                               value="@message.Id" />

                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="confirmDelete(this)">
                                            <span class="material-symbols-outlined align-middle me-1" style="font-size: 17px;">
                                                delete
                                            </span>
                                            Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="message-empty">
            <div class="message-empty-icon">
                <span class="material-symbols-outlined">
                    mail
                </span>
            </div>

            <h5 class="mb-2">Henüz mesaj bulunmuyor</h5>

            <p class="text-muted mb-0">
                İletişim formundan gönderilen mesajlar burada görüntülenecektir.
            </p>
        </div>
    }
</div>

<script>
    function confirmDelete(button) {
        const form = button.closest("form");

        Swal.fire({
            title: "Mesaj silinsin mi?",
            text: "Bu işlemi geri alamazsınız.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc3545",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Evet, sil",
            cancelButtonText: "İptal"
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    }
</script>