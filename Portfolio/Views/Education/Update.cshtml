@model Education

@{
    Layout = "~/Views/Admin/Layout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Eğitim Bilgisini Güncelle</h2>

        <p class="admin-page-description">
            Seçilen eğitim kaydının bilgilerini düzenleyebilirsiniz.
        </p>
    </div>

    <a asp-controller="Education"
       asp-action="Index"
       class="btn btn-outline-secondary">
        <span class="material-symbols-outlined align-middle me-1"
              style="font-size: 19px;">
            arrow_back
        </span>
        Listeye Dön
    </a>
</div>

<div class="admin-form-card shadow-sm">
    
    <form asp-controller="Education"
          asp-action="Update"
          method="post">

        <input asp-for="Id" type="hidden" />

        <div class="admin-form-body">
            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="SchoolName" class="admin-form-label">
                        Okul veya Kurum Adı
                    </label>

                    <input asp-for="SchoolName"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="SchoolName"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Department" class="admin-form-label">
                        Bölüm veya Eğitim Programı
                    </label>

                    <input asp-for="Department"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="Department"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-md-4">
                    <label asp-for="StartYear" class="admin-form-label">
                        Başlangıç Tarihi
                    </label>

                    <input asp-for="StartYear"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="StartYear"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-md-4">
                    <label asp-for="GraduationYear" class="admin-form-label">
                        Mezuniyet Tarihi
                    </label>

                    <input asp-for="GraduationYear"
                           id="graduationYear"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="GraduationYear"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-md-4">
                    <label asp-for="GPA" class="admin-form-label">
                        Genel Not Ortalaması
                    </label>

                    <input asp-for="GPA"
                           type="number"
                           min="0"
                           max="4"
                           step="0.01"
                           class="form-control admin-form-control" />

                    <span asp-validation-for="GPA"
                          class="text-danger small">
                    </span>
                </div>

                <div class="col-12">
                    <div class="admin-option-box">
                        <div class="form-check form-switch">
                            <input asp-for="IsCurrent"
                                   id="educationCurrent"
                                   class="form-check-input"
                                   type="checkbox" />

                            <label asp-for="IsCurrent"
                                   class="form-check-label fw-semibold">
                                Bu eğitime hâlâ devam ediyorum
                            </label>
                        </div>

                        <p class="admin-option-description">
                            Seçildiğinde mezuniyet yılı temizlenir.
                        </p>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="admin-form-label">
                        Açıklama
                    </label>

                    <textarea asp-for="Description"
                              maxlength="1000"
                              class="form-control admin-form-control"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger small">
                    </span>
                </div>
            </div>
        </div>

        <div class="admin-form-footer">
            <button type="submit" class="btn btn-primary">
                <span class="material-symbols-outlined align-middle me-1"
                      style="font-size: 19px;">
                    check
                </span>
                Değişiklikleri Kaydet
            </button>
        </div>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const currentCheckbox =
            document.getElementById("educationCurrent");

        const graduationYear =
            document.getElementById("graduationYear");

        function updateGraduationYear() {
            graduationYear.disabled = currentCheckbox.checked;

            if (currentCheckbox.checked) {
                graduationYear.value = "";
            }
        }

        currentCheckbox.addEventListener(
            "change",
            updateGraduationYear
        );

        updateGraduationYear();
    });
</script>