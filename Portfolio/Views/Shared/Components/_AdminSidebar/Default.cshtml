@*
    admin sidebar component
*@

@{
    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString();

    var currentAction =
        ViewContext.RouteData.Values["action"]?.ToString();

    string ActiveLink(string controller, string? action = null)
    {
        var controllerMatches = string.Equals(
            currentController,
            controller,
            StringComparison.OrdinalIgnoreCase);

        var actionMatches = string.IsNullOrWhiteSpace(action) ||
                            string.Equals(
                                currentAction,
                                action,
                                StringComparison.OrdinalIgnoreCase);

        return controllerMatches && actionMatches
            ? "active"
            : string.Empty;
    }
}
<style>
    .sidebar-menu {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
        padding: 10px 8px 25px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .sidebar-section-title {
        margin: 22px 14px 8px;
        color: #94a3b8;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.13em;
        white-space: nowrap;
    }

    .sidebar-link {
        position: relative;
        display: flex;
        align-items: center;
        gap: 11px;
        min-height: 46px;
        margin: 3px 4px;
        padding: 7px 12px;
        color: #64748b;
        text-decoration: none !important;
        border: 1px solid transparent;
        border-radius: 11px;
        transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    }

        .sidebar-link:hover {
            color: #2563eb;
            background: #eff6ff;
            border-color: #dbeafe;
            transform: translateX(3px);
        }

    .sidebar-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        flex-shrink: 0;
        border-radius: 9px;
        background: #f1f5f9;
        color: #64748b;
        transition: all 0.2s ease;
    }

        .sidebar-icon .material-symbols-outlined {
            font-size: 20px;
        }

    .sidebar-text {
        overflow: hidden;
        font-size: 13px;
        font-weight: 500;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .sidebar-external-icon {
        margin-left: auto;
        color: #94a3b8;
        font-size: 16px;
    }

    /* Aktif sayfa */
    .sidebar-link.active {
        color: #ffffff;
        background: linear-gradient( 135deg, #2563eb 0%, #4f46e5 100% );
        border-color: transparent;
        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.23);
        transform: translateX(3px);
    }

        .sidebar-link.active::before {
            position: absolute;
            top: 50%;
            left: -5px;
            width: 4px;
            height: 24px;
            content: "";
            background: #60a5fa;
            border-radius: 0 6px 6px 0;
            transform: translateY(-50%);
        }

        .sidebar-link.active .sidebar-icon {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.16);
        }

        .sidebar-link.active .sidebar-text {
            font-weight: 600;
        }

        .sidebar-link.active:hover {
            color: #ffffff;
            background: linear-gradient( 135deg, #1d4ed8 0%, #4338ca 100% );
        }

    .sidebar-menu::-webkit-scrollbar {
        width: 5px;
    }

    .sidebar-menu::-webkit-scrollbar-track {
        background: transparent;
    }

    .sidebar-menu::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

        .sidebar-menu::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
</style>

