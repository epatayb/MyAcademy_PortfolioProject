@model List<Service>
@*
    default services component
*@

<section id="services"
         class="relative bg-surface-container-lowest
                py-section-padding-mobile
                md:py-section-padding-desktop
                px-gutter">

    <div class="max-w-container-max mx-auto">

        <!-- Bölüm Başlığı -->
        <div class="mb-stack-lg">
            <h2 class="font-headline-md text-headline-md text-on-background">
                Uzmanlık Alanlarım
            </h2>

            <p class="font-body-md text-body-md text-on-surface-variant mt-2 max-w-2xl">
                .NET teknolojileriyle geliştirdiğim projelerde backend sistemlerinden
                kullanıcı arayüzlerine kadar farklı alanlarda çalışmalar gerçekleştiriyorum.
            </p>
        </div>

        <!-- Kartlar -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
            @foreach (var item in Model)
            {                
            <div class="glass-card p-stack-lg rounded-xl
                        flex flex-col gap-stack-sm
                        hover:-translate-y-2
                        transition-transform duration-300">

                <span class="material-symbols-outlined text-primary text-4xl mb-stack-sm"
                      style="font-variation-settings: 'FILL' 0;">
                        @item.Icon
                </span>

                <h3 class="font-body-lg text-body-lg font-semibold text-on-background">
                        @item.Title
                </h3>

                <p class="font-body-md text-body-md text-on-surface-variant">
                    @item.Description
                </p>
            </div>
            }
        </div>
    </div>
</section>