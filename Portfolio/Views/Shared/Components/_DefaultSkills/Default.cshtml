@*
    default skills component view
*@

@model List<Skill>

<div class="mt-stack-sm">
    <h4 class="font-label-md text-label-md text-primary mb-1">Kullandığım Teknolojiler</h4>

    @if (Model.Any())
    {
        <p class="font-body-md text-body-md text-on-surface-variant">
            @string.Join(", ", Model.Select(x => x.Name))
        </p>
    }
    else
    {
        <p class="font-body-md text-body-md text-on-surface-variant">
            Henüz yetenek bilgisi eklenmedi.
        </p>
    }

</div>