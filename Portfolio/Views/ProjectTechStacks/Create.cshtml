@model ProjectTechStack
@{
    ViewData["Title"] = "Proje Teknolojileri Oluştur";
    Layout = "~/Views/Admin/Layout.cshtml";
}

<form action="/" method="post">
    <label>Proje Adı:</label>
    <select class="form-control" asp-for="ProjectId" asp-items="@ViewBag.projects" required>
        <option selected disabled>---Projeyi Seçiniz---</option>
    </select>
    <br />
    <label>Teknoloji Adı:</label>
    <select class="form-control" asp-for="TechStackId" asp-items="@ViewBag.techStacks" required>
        <option selected disabled>---Teknolojiyi Seçiniz---</option>
    </select>
    <br />

    <button type="submit" class="btn btn-outline-dark">Kaydet</button>
</form>