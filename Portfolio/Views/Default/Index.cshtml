@{
    Layout = null;
}

<!DOCTYPE html>
<html class="dark scroll-smooth" lang="tr">

@await Component.InvokeAsync("_DefaultHead")

<body class="bg-background text-on-background antialiased selection:bg-primary/30 selection:text-primary" id="home">
    <!-- TopNavBar -->
    @await Component.InvokeAsync("_DefaultTopNavBar")
    <main class="pt-20">
        <!-- Hero Section -->
        <section class="relative min-h-[921px] flex items-center pt-section-padding-mobile pb-section-padding-mobile md:pt-section-padding-desktop md:pb-section-padding-desktop px-gutter overflow-hidden" id="hero">
            <div class="glow-accent top-1/4 left-1/4"></div>
            <div class="max-w-container-max mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-stack-lg items-center relative z-10">
                <div class="flex flex-col gap-stack-md">
                    <h1 class="font-display-lg-mobile text-display-lg-mobile md:font-display-lg md:text-display-lg text-on-background">Building Digital Experiences with <span class="text-gradient">Precision</span></h1>
                    <p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg">I engineer elegant, high-performance web applications, merging technical rigor with minimalist design to solve complex business problems.</p>
                    <div class="flex items-center gap-stack-md mt-stack-md">
                        <a class="inline-flex items-center justify-center px-8 py-4 bg-primary text-on-primary rounded-DEFAULT font-label-sm text-label-sm hover:opacity-90 transition-opacity" href="#portfolio">View My Work</a>
                        <a class="inline-flex items-center justify-center px-8 py-4 border border-outline text-on-background rounded-DEFAULT font-label-sm text-label-sm hover:bg-surface-variant/30 transition-colors" href="#contact">Contact Me</a>
                    </div>
                </div>
                <div class="relative w-full aspect-square md:aspect-[4/3] lg:aspect-square rounded-xl overflow-hidden glass-card">
                    <img alt="Abstract code on screen" class="w-full h-full object-cover opacity-80 mix-blend-luminosity hover:mix-blend-normal transition-all duration-700" data-alt="A striking abstract technological composition showing lines of glowing code on a dark computer monitor, creating a modern, minimalist vibe. The environment is dark and moody, illuminated only by the cool blue and intense indigo light radiating from the screen. The scene embodies digital precision, professional software engineering, and premium tech aesthetics, perfect for a high-end dark-mode portfolio hero image." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDWe9lBVsD8m_UMgZWjg1xjuueKIEqPOD9088j_UEd01lPF-jtLb3f54hfBqmat6w0ltEwwlQMKtWEi8aeCmvWtNABT0y3cWaedgtq0v5_LZ2I0OoX746EhQdqbisUu0gLlopYmYiMA2RVuRhgSkgyUECdPHkmzcuy-nATEFrwD_L8DA4zBLWDntwqyHwqOPKSyA6OkaEsPubD3xALYXWKiCjjY50O9BlKJwaywNmQkLusLpGiqQfY-ywjiFZMIwFgEGyBUTztm521J" />
                </div>
            </div>
        </section>
        <!-- About Section -->
        @await Component.InvokeAsync("_DefaultAbout")
        <!-- Experience & Education Section -->
        <section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative" id="experience">
            <div class="max-w-container-max mx-auto">
                <div class="text-center mb-stack-lg">
                    <h2 class="font-headline-md text-headline-md text-on-background">Kariyer Yolculuğum</h2>
                    <p class="font-body-md text-body-md text-on-surface-variant mt-2">Eğitim hayatım, deneyimlerim ve gelişim sürecim.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
                    <!-- Experience -->
                    @await Component.InvokeAsync("_DefaultExperience")
                    <!-- Education -->
                    @await Component.InvokeAsync("_DefaultEducation")                    
                </div>
            </div>
        </section>

        <!-- Services Section -->
        @await Component.InvokeAsync("_DefaultServices")

        <!-- Project Slider Section -->
        @await Component.InvokeAsync("_DefaultProject")                      

        <!-- Contact Section -->
        <section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative bg-surface-container-lowest" id="contact">
            <div class="max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-stack-lg">
                @await Component.InvokeAsync("_DefaultContactInfo")

                @await Component.InvokeAsync("_DefaultUserMessage")
            </div>
        </section>

        <!-- Footer -->
        @await Component.InvokeAsync("_DefaultFooter")
        
    </main>

</body>
</html>