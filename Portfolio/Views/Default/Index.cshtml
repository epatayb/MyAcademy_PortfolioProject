@{
    Layout = null;
}

<!DOCTYPE html>
<html class="dark scroll-smooth" lang="tr">

@await Component.InvokeAsync("_DefaultHead")

<body class="bg-background text-on-background antialiased selection:bg-primary/30 selection:text-primary" id="home">
    <!-- TopNavBar -->
    @await Component.InvokeAsync("_DefaultTopNavBar")
    <main class="pt-20">
        <!-- Hero Section -->
        @await Component.InvokeAsync("_DefaultHero")
        
        <!-- About Section -->
        @await Component.InvokeAsync("_DefaultAbout")
        <!-- Experience & Education Section -->
        <section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative" id="experience">
            <div class="max-w-container-max mx-auto">
                <div class="text-center mb-stack-lg">
                    <h2 class="font-headline-md text-headline-md text-on-background">Kariyer Yolculuğum</h2>
                    <p class="font-body-md text-body-md text-on-surface-variant mt-2">Eğitim hayatım, deneyimlerim ve gelişim sürecim.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
                    <!-- Experience -->
                    @await Component.InvokeAsync("_DefaultExperience")
                    <!-- Education -->
                    @await Component.InvokeAsync("_DefaultEducation")                    
                </div>
            </div>
        </section>

        <!-- Services Section -->
        @await Component.InvokeAsync("_DefaultServices")

        <!-- Project Slider Section -->
        @await Component.InvokeAsync("_DefaultProject")                      

        <!-- Contact Section -->
        <section class="py-section-padding-mobile md:py-section-padding-desktop px-gutter relative bg-surface-container-lowest" id="contact">
            <div class="max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-stack-lg">
                @await Component.InvokeAsync("_DefaultContactInfo")

                @await Component.InvokeAsync("_DefaultUserMessage")
            </div>
        </section>

        <!-- Footer -->
        @await Component.InvokeAsync("_DefaultFooter")
        
    </main>

</body>
</html>