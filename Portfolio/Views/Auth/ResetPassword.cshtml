@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Yeni Şifre Belirle";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<main class="admin-login-page">
    <section class="admin-login-brand">
        <div class="admin-login-grid-pattern"></div>

        <div class="admin-login-brand-content">
            <div class="admin-login-logo">
                <span class="admin-login-logo-icon">
                    <span class="material-symbols-outlined">
                        terminal
                    </span>
                </span>

                <span class="admin-login-logo-text">
                    Portfolio Admin
                </span>
            </div>

            <div class="admin-login-introduction">
                <h1>
                    Yeni şifrenizi belirleyin
                </h1>

                <p>
                    Yönetim paneliniz için güçlü ve daha önce
                    kullanmadığınız bir şifre oluşturun.
                </p>
            </div>
        </div>
    </section>

    <section class="admin-login-form-section">
        <div class="admin-login-card">
            <div class="admin-login-card-header">
                <span class="admin-login-card-icon">
                    <span class="material-symbols-outlined">
                        password
                    </span>
                </span>

                <div>
                    <h2>Yeni Şifre Belirle</h2>

                    <p>
                        Şifreniz en az 8 karakter olmalıdır.
                    </p>
                </div>
            </div>

            <form asp-controller="Auth"
                  asp-action="ResetPassword"
                  method="post">

                <input asp-for="AdminId"
                       type="hidden" />

                <input asp-for="Token"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="admin-login-alert">
                </div>

                <div class="admin-login-field">
                    <label asp-for="NewPassword">
                        Yeni Şifre
                    </label>

                    <div class="admin-login-input-wrapper">
                        <span class="admin-login-input-icon material-symbols-outlined">
                            lock
                        </span>

                        <input asp-for="NewPassword"
                               class="admin-login-input"
                               placeholder="Yeni şifrenizi girin"
                               autocomplete="new-password" />
                    </div>

                    <span asp-validation-for="NewPassword"
                          class="admin-login-validation">
                    </span>
                </div>

                <div class="admin-login-field">
                    <label asp-for="ConfirmPassword">
                        Yeni Şifre Tekrarı
                    </label>

                    <div class="admin-login-input-wrapper">
                        <span class="admin-login-input-icon material-symbols-outlined">
                            lock_reset
                        </span>

                        <input asp-for="ConfirmPassword"
                               class="admin-login-input"
                               placeholder="Yeni şifrenizi tekrar girin"
                               autocomplete="new-password" />
                    </div>

                    <span asp-validation-for="ConfirmPassword"
                          class="admin-login-validation">
                    </span>
                </div>

                <button type="submit"
                        class="admin-login-submit">

                    <span class="material-symbols-outlined">
                        save
                    </span>

                    Şifreyi Güncelle
                </button>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}