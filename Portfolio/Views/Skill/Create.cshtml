@model Skill

@{
    Layout = "~/Views/Admin/Layout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">
            Yeni Yetenek Ekle
        </h2>

        <p class="admin-page-description">
            Portfolyonuzda göstereceğiniz yeni bir yetenek oluşturun.
        </p>
    </div>

    <a asp-controller="Skill"
       asp-action="Index"
       class="btn btn-outline-secondary">

        <span class="material-symbols-outlined align-middle me-1"
              style="font-size: 18px;">
            arrow_back
        </span>

        Listeye Dön
    </a>
</div>

<div class="admin-form-card shadow-sm">
    <div class="admin-form-header">
        <h5 class="mb-1">
            Yetenek Bilgileri
        </h5>

        <p class="text-muted small mb-0">
            Yetenek veya uzmanlık alanınızı girin.
        </p>
    </div>

    <form asp-controller="Skill"
          asp-action="Create"
          method="post">

        <div class="admin-form-body">
            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger mb-4">
            </div>

            <div class="row g-4">
                <div class="col-lg-12">
                    <label asp-for="Name"
                           class="admin-form-label">
                        Yetenek Adı
                    </label>

                    <input asp-for="Name"
                           id="skillNameInput"
                           class="form-control admin-form-control"
                           required
                           placeholder="Örneğin: REST API Geliştirme"
                           autocomplete="off" />

                    <span asp-validation-for="Name"
                          class="text-danger small">
                    </span>
                </div>
            </div>
        </div>

        <div class="admin-form-footer">
            <button type="submit"
                    class="btn btn-primary">

                <span class="material-symbols-outlined align-middle me-1"
                      style="font-size: 18px;">
                    check
                </span>

                Yeteneği Kaydet
            </button>
        </div>
    </form>
</div>